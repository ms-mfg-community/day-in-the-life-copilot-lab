@model ContosoUniversity.Web.Models.CourseViewModel

@{
    ViewBag.Title = "Edit";
}

<h2>Edit</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <div class="form-horizontal">
        <h4>Course</h4>
        <hr />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input asp-for="CourseID" type="hidden" />

        <div class="form-group">
            <label asp-for="CourseID" class="control-label col-md-2"></label>
            <div class="col-md-10">
                <input asp-for="CourseID" class="form-control" readonly />
                <span asp-validation-for="CourseID" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Title" class="control-label col-md-2"></label>
            <div class="col-md-10">
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Credits" class="control-label col-md-2"></label>
            <div class="col-md-10">
                <input asp-for="Credits" class="form-control" />
                <span asp-validation-for="Credits" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="DepartmentID" class="control-label col-md-2">Department</label>
            <div class="col-md-10">
                <select asp-for="DepartmentID" class="form-control" asp-items="ViewBag.DepartmentID"></select>
                <span asp-validation-for="DepartmentID" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="TeachingMaterialImage" class="control-label col-md-2">Teaching Material Image</label>
            <div class="col-md-10">
                @if (!string.IsNullOrEmpty(Model.TeachingMaterialImagePath))
                {
                    <div class="current-image" style="margin-bottom: 10px;">
                        <p><strong>Current Image:</strong></p>
                        <img src="@Url.Content(Model.TeachingMaterialImagePath)" alt="Teaching Material" style="max-width: 200px; max-height: 200px; border: 1px solid #ddd; padding: 5px;" />
                    </div>
                }
                <input asp-for="TeachingMaterialImage" type="file" accept="image/*" class="form-control" />
                <small class="text-muted">Supported formats: JPG, JPEG, PNG, GIF, BMP. Max size: 5MB. Leave empty to keep current image.</small>
                <span asp-validation-for="TeachingMaterialImage" class="text-danger"></span>
                <input asp-for="TeachingMaterialImagePath" type="hidden" />
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Save" class="btn btn-default" />
            </div>
        </div>
    </div>
</form>

<div>
    @Html.ActionLink("Back to List", "Index")
</div>

@section Scripts {

}
