@using Microsoft.AspNetCore.Identity

@if (User.Identity?.IsAuthenticated == true)
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link text-light" title="Welcome">Hello @User.Identity.Name!</a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="" asp-controller="Account" asp-action="SignOut">
                <button type="submit" class="nav-link btn btn-link text-light">Sign out</button>
            </form>
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link text-light" asp-area="" asp-controller="Account" asp-action="SignIn">Sign in</a>
        </li>
    </ul>
}
