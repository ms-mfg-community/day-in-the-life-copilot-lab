{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./scripts/hooks/user-prompt-submitted.sh",
        "powershell": "./scripts/hooks/user-prompt-submitted.ps1",
        "timeoutSec": 5,
        "comment": "Log user prompts for audit trail"
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "./scripts/hooks/pre-tool-use-long-running.sh",
        "powershell": "./scripts/hooks/pre-tool-use-long-running.ps1",
        "timeoutSec": 5,
        "comment": "Warn about long-running commands (npm, pnpm, yarn, cargo, docker)"
      },
      {
        "type": "command",
        "bash": "./scripts/hooks/pre-tool-use-doc-blocker.sh",
        "powershell": "./scripts/hooks/pre-tool-use-doc-blocker.ps1",
        "timeoutSec": 5,
        "comment": "Block creation of unnecessary .md/.txt documentation files"
      },
      {
        "type": "command",
        "bash": "./scripts/hooks/pre-tool-use-secret-scan.sh",
        "powershell": "./scripts/hooks/pre-tool-use-secret-scan.ps1",
        "timeoutSec": 10,
        "comment": "Block commits containing hardcoded secrets or credentials"
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./scripts/hooks/post-tool-use-format.sh",
        "powershell": "./scripts/hooks/post-tool-use-format.ps1",
        "timeoutSec": 15,
        "comment": "Auto-format JS/TS files after edit with Prettier"
      },
      {
        "type": "command",
        "bash": "./scripts/hooks/post-tool-use-console-warn.sh",
        "powershell": "./scripts/hooks/post-tool-use-console-warn.ps1",
        "timeoutSec": 5,
        "comment": "Warn about console.log statements in edited files"
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "./scripts/hooks/error-occurred.sh",
        "powershell": "./scripts/hooks/error-occurred.ps1",
        "timeoutSec": 10,
        "comment": "Log errors with context for debugging"
      }
    ]
  }
}
