{
  "mcpServers": {
    "session-broker": {
      "type": "http",
      "url": "http://localhost:3456/mcp",
      "headers": {
        "Accept": "text/event-stream"
      }
    },
    "fetch": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@kazuph/mcp-fetch"],
      "tools": ["*"]
    }
  }
}
