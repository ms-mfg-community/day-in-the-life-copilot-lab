#!/usr/bin/env node
// gh-clab — a GitHub CLI extension (interpreted, Node) that summarizes the
// working-tree diff into a structured changelog. Three runtime modes:
//   1. Primary : `gh models run <model> "<prompt>"` (auth inherited from gh).
//   2. Fallback: OpenAI-compatible HTTP endpoint (OPENAI_API_KEY or AZURE_OPENAI_*).
//   3. Mock    : GH_CLAB_MOCK=1 or both upstreams unavailable → canned output.
'use strict';

const { spawnSync } = require('node:child_process');

const MODEL = process.env.GH_CLAB_MODEL || 'openai/gpt-4o-mini';
const PROMPT_PREFIX =
  'Summarize the following git diff as a terse, structured changelog. ' +
  'Group by Added / Changed / Fixed / Removed. Keep it under 12 bullets.\n\n';

function readDiff() {
  const r = spawnSync('git', ['diff', '--no-color', 'HEAD'], { encoding: 'utf8' });
  if (r.status !== 0) return '';
  return (r.stdout || '').slice(0, 60_000);
}

function which(cmd) {
  const r = spawnSync('sh', ['-c', `command -v ${cmd}`], { encoding: 'utf8' });
  return r.status === 0 && r.stdout.trim().length > 0;
}

function ghModelsAvailable() {
  if (!which('gh')) return false;
  const r = spawnSync('gh', ['extension', 'list'], { encoding: 'utf8' });
  return r.status === 0 && /\bgithub\/gh-models\b/.test(r.stdout || '');
}

function pickMode(argv) {
  if (argv.includes('--mock') || process.env.GH_CLAB_MOCK === '1') return 'mock';
  if (ghModelsAvailable()) return 'gh-models';
  if (process.env.OPENAI_API_KEY || process.env.AZURE_OPENAI_API_KEY) return 'openai';
  return 'mock';
}

function runGhModels(prompt) {
  const r = spawnSync('gh', ['models', 'run', MODEL, prompt], { encoding: 'utf8' });
  if (r.status !== 0) throw new Error(r.stderr || 'gh models run failed');
  return r.stdout.trim();
}

async function runOpenAI(prompt) {
  const isAzure = !!process.env.AZURE_OPENAI_API_KEY;
  const url = isAzure
    ? `${process.env.AZURE_OPENAI_ENDPOINT}/openai/deployments/${process.env.AZURE_OPENAI_DEPLOYMENT}/chat/completions?api-version=2024-08-01-preview`
    : 'https://api.openai.com/v1/chat/completions';
  const headers = { 'content-type': 'application/json' };
  if (isAzure) headers['api-key'] = process.env.AZURE_OPENAI_API_KEY;
  else headers['authorization'] = `Bearer ${process.env.OPENAI_API_KEY}`;
  const body = {
    model: isAzure ? process.env.AZURE_OPENAI_DEPLOYMENT : (process.env.OPENAI_MODEL || 'gpt-4o-mini'),
    messages: [{ role: 'user', content: prompt }],
  };
  const res = await fetch(url, { method: 'POST', headers, body: JSON.stringify(body) });
  if (!res.ok) throw new Error(`openai endpoint: ${res.status} ${await res.text()}`);
  const json = await res.json();
  return (json.choices?.[0]?.message?.content || '').trim();
}

function mockOutput() {
  return [
    '## Changelog (mock)',
    '',
    '### Added',
    '- `gh clab` extension scaffold with three-mode fallback.',
    '',
    '### Changed',
    '- Refactored diff pipeline to call `gh models run`.',
    '',
    '### Fixed',
    '- N/A',
    '',
    '### Removed',
    '- N/A',
    '',
    '_Generated by GH_CLAB_MOCK — no credentials were used._',
  ].join('\n');
}

async function main() {
  const argv = process.argv.slice(2);
  const diff = readDiff();
  if (!diff.trim() && !argv.includes('--allow-empty')) {
    console.error('gh clab: no staged or unstaged diff against HEAD. Use --allow-empty to force.');
    process.exit(2);
  }
  const mode = pickMode(argv);
  const prompt = PROMPT_PREFIX + (diff || '(empty diff)');
  try {
    if (mode === 'mock') {
      console.log(mockOutput());
      return;
    }
    if (mode === 'gh-models') {
      console.log(runGhModels(prompt));
      return;
    }
    console.log(await runOpenAI(prompt));
  } catch (err) {
    console.error(`gh clab: ${mode} mode failed: ${err.message}`);
    console.error('gh clab: falling back to mock output.');
    console.log(mockOutput());
  }
}

main();
